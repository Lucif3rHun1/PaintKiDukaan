{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "splash",
  "description": "IPC capabilities for the update splash screen (matches splash + splash-{attempt} windows)",
  "windows": ["splash*"],
  "permissions": [
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "retry_update",
    "quit_app"
  ]
}
